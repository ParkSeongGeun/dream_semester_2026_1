# ============================================
# ComfortableMove 환경 변수 템플릿
# ============================================
# 환경별 .env 파일 구성:
#   .env         - 로컬 개발 (Docker 미사용, localhost 접속)
#   .env.docker  - Docker 프로덕션 (서비스명으로 접속)
#   .env.dev     - Docker 개발환경 (docker-compose.dev.yml)
#   .env.test    - Docker 테스트환경 (docker-compose.test.yml)
#
# 사용법:
#   1. 이 파일을 .env로 복사: cp .env.example .env
#   2. 값을 실제 환경에 맞게 수정
# ============================================

# 환경 설정
ENVIRONMENT=development          # development | staging | production | testing
DEBUG=true

# 데이터베이스
# Docker 환경에서는 localhost 대신 서비스명(postgres) 사용
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/comfortablemove
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
# Docker 환경에서는 localhost 대신 서비스명(redis) 사용
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_BUS_ARRIVAL=60         # 버스 도착 정보 캐시 TTL (초)
REDIS_TTL_STATISTICS=300         # 통계 캐시 TTL (초)

# 서울시 버스 API
SEOUL_BUS_API_BASE_URL=http://ws.bus.go.kr/api/rest
SEOUL_BUS_API_KEY=your_api_key_here
SEOUL_BUS_API_TIMEOUT=10
SEOUL_BUS_API_MAX_RETRIES=3

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Docker Compose용 추가 변수
POSTGRES_USER=user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=comfortablemove

# 보안
SECRET_KEY=your-secret-key-change-this-in-production
