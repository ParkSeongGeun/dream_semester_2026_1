# 환경 설정
ENVIRONMENT=development
DEBUG=true

# 데이터베이스
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/comfortablemove
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_BUS_ARRIVAL=60
REDIS_TTL_STATISTICS=300

# 서울시 버스 API
SEOUL_BUS_API_BASE_URL=http://ws.bus.go.kr/api/rest
SEOUL_BUS_API_KEY=your_api_key_here
SEOUL_BUS_API_TIMEOUT=10
SEOUL_BUS_API_MAX_RETRIES=3

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Docker Compose용 추가 변수
POSTGRES_USER=user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=comfortablemove
