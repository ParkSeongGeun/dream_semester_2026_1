aws_access_key     = "YOUR_AWS_ACCESS_KEY"
aws_secret_key     = "YOUR_AWS_SECRET_KEY"

my_ip              = "1.2.3.4/32"
db_password        = "CHANGE_ME_STRONG_PASSWORD"
notification_email = "your-email@example.com"

