# Jenkins 관리자 계정 (JCasC 가 이 값으로 계정 생성)
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin123!
JENKINS_URL=http://localhost:8080/

# Slack 빌드 알림 (선택) — 미설정 시 알림 단계는 건너뜀
SLACK_TEAM=
SLACK_TOKEN=
SLACK_CHANNEL=

# AWS ECR 푸시 (선택) — 미설정 시 Push 단계는 건너뜀
# Jenkins 자격증명(credentials)으로 등록하는 것을 권장
ECR_REGISTRY=
AWS_REGION=ap-northeast-2
